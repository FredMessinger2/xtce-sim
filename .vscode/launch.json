{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Sim: imaging_sat",
      "type": "debugpy",
      "request": "launch",
      "module": "xtce_sim.cli",
      "args": [
        "run", "examples/imaging_sat/imaging_sat.xml",
        "--id", "sat-a", "--port", "5000"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Monitor: sat-a",
      "type": "debugpy",
      "request": "launch",
      "module": "xtce_sim.cli",
      "args": ["monitor", "--id", "sat-a", "--port", "5000"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "UI: sat-a",
      "type": "debugpy",
      "request": "launch",
      "module": "xtce_sim.cli",
      "args": ["ui", "--id", "sat-a", "--port", "5000", "--http-port", "8080"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Send: SET_POWER",
      "type": "debugpy",
      "request": "launch",
      "module": "xtce_sim.cli",
      "args": [
        "send", "--id", "sat-a", "--port", "5000",
        "SET_POWER", "SubsystemId=2", "PowerState=ON"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Upload: a sequence file",
      "type": "debugpy",
      "request": "launch",
      "module": "xtce_sim.cli",
      "args": [
        "upload", "${input:uploadFile}",
        "--id", "sat-a", "--port", "5000",
        "--timeout", "10m"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug: parse XTCE (generate)",
      "type": "debugpy",
      "request": "launch",
      "module": "xtce_sim.cli",
      "args": [
        "generate", "examples/imaging_sat/imaging_sat.xml",
        "--out", "runs/debug"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Pytest: current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ],
  "inputs": [
    {
      "id": "uploadFile",
      "type": "promptString",
      "description": "File to upload to the vehicle's store",
      "default": "/tmp/plan.ats"
    }
  ]
}
