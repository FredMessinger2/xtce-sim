{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Server: run example (--live)",
      "type": "debugpy",
      "request": "launch",
      "module": "xtce_sim.cli",
      "args": ["run", "examples/my_vehicle.xml", "--id", "sat-a", "--port", "5000", "--live", "--interval", "5"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Server: run imaging_sat (--live)",
      "type": "debugpy",
      "request": "launch",
      "module": "xtce_sim.cli",
      "args": ["run", "examples/imaging_sat.xml", "--id", "img", "--port", "5001", "--live", "--interval", "5"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Monitor: sat-a",
      "type": "debugpy",
      "request": "launch",
      "module": "xtce_sim.cli",
      "args": ["monitor", "--id", "sat-a", "--port", "5000"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Send: SET_POWER",
      "type": "debugpy",
      "request": "launch",
      "module": "xtce_sim.cli",
      "args": [
        "send", "--id", "sat-a", "--port", "5000",
        "SET_POWER", "SubsystemId=2", "PowerState=ON"
      ],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug: parse XTCE (generate)",
      "type": "debugpy",
      "request": "launch",
      "module": "xtce_sim.cli",
      "args": ["generate", "examples/my_vehicle.xml", "--out", "runs/debug"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": true
    },
    {
      "name": "Pytest: current file",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["${file}", "-v"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
