{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "test",
      "type": "shell",
      "command": "uv run pytest -q",
      "group": { "kind": "test", "isDefault": true },
      "problemMatcher": []
    },
    {
      "label": "test (coverage)",
      "type": "shell",
      "command": "uv run pytest --cov=xtce_sim --cov-report=term-missing",
      "group": "test",
      "problemMatcher": []
    },
    {
      "label": "lint",
      "type": "shell",
      "command": "uv run ruff check xtce_sim tests",
      "problemMatcher": []
    },
    {
      "label": "run server (example)",
      "type": "shell",
      "command": "uv run xtce-sim run examples/imaging_sat/imaging_sat.xml --id sat-a --port 5000",
      "isBackground": true,
      "problemMatcher": []
    }
  ]
}
